# === EVO-core Environment Variables ===
# Скопируй в .env и заполни

# PostgreSQL
DATABASE_URL=postgresql://evo_user:password@localhost:5432/evo_core

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Router — основная модель
GEMINI_API_KEY=your_gemini_api_key_here

# Безопасность
EVO_HMAC_SECRET=generate_random_32_char_string_here
EVO_API_SECRET=generate_random_32_char_string_here

# Шарды (бесплатные облака)
SHARD_PRIMARY_HOST=your_shard_host
SHARD_MIRROR_HOST=your_mirror_host

# Уведомления (заполнить для режима СОН)
TG_BOT_TOKEN=your_telegram_bot_token
TG_ADMIN_CHAT_ID=your_chat_id

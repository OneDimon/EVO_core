# === EVO-core Environment Variables ===
# Скопируй в .env и заполни все обязательные поля
# EVO_ENV=development — для локальной разработки (отключает проверки секретов)

EVO_ENV=production

# ── ОБЯЗАТЕЛЬНЫЕ (без них старт заблокирован в production) ──────────────────
DATABASE_URL=postgresql://evo_user:password@localhost:5432/evo_core
REDIS_URL=redis://localhost:6379/0
GEMINI_API_KEY=your_gemini_api_key_here
EVO_HMAC_SECRET=generate_random_64_char_string_here_minimum_32_required
EVO_API_SECRET=generate_random_64_char_string_here_for_admin_access
EVO_ENCRYPTION_KEY=generate_random_64_char_string_here_for_db_encryption
EVO_MASTER_KEY=generate_random_64_char_string_for_dev_bypass

# ── AI Router ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=optional_openai_key
OLLAMA_HOST=http://localhost:11434
RATE_LIMIT_RPM=60

# ── Шарды (вносятся через Admin UI после старта, НЕ сюда — шифруются AES) ──
# SHARD_PROVIDER=local|gdrive|github|r2  (default: local для тестов)
# SHARD_PRIMARY_HOST=
# SHARD_MIRROR_HOST=
# SHARD_GDRIVE_CREDENTIALS_JSON=  (содержимое service account JSON целиком, одной строкой)
# SHARD_GDRIVE_ROOT_FOLDER=       (Drive folder ID корневой папки шарда — НЕ имя папки!
#                                   найти: открыть папку в Drive, ID — в URL после /folders/)
# SHARD_GITHUB_TOKEN=
# SHARD_GITHUB_REPO=owner/repo
# SHARD_R2_ACCOUNT_ID=
# SHARD_R2_ACCESS_KEY=
# SHARD_R2_SECRET_KEY=
# SHARD_R2_BUCKET=

# ── n8n — Immune System reanimator (Блок 07, см. n8n/README_n8n.md) ────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=generate_random_string_here
# N8N_WEBHOOK_URL=  (заполнить после импорта и активации воркфлоу в n8n UI,
#                    см. n8n/README_n8n.md п.3-4; внутри docker-сети ядро
#                    вызывает n8n по адресу http://n8n:5678/webhook/...)

# ── Уведомления Архитектора (через Admin UI) ────────────────────────────────
# TG_BOT_TOKEN=
# TG_ADMIN_CHAT_ID=
# ADMIN_NOTIFY_URL=http://localhost:8000/admin/api/notifications

# ── PostgreSQL шифрование ────────────────────────────────────────────────────
# Устанавливается автоматически из EVO_ENCRYPTION_KEY
# DB_ENCRYPTION_KEY=same_as_EVO_ENCRYPTION_KEY

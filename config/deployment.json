{
  "_comment": "EVO-core deployment config. Скопируй в deployment.json и заполни.",
  "_doc": "Описание: PROJECT_MAP.md, AI_ONBOARDING.md раздел Порядок запуска",

  "api": {
    "host": "0.0.0.0",
    "port": 8000,
    "workers": 4,
    "secret_key_env": "SECRET_KEY",
    "hmac_key_env": "HMAC_SECRET_KEY"
  },

  "postgres": {
    "host": "postgres",
    "port": 5432,
    "db": "evodb",
    "user": "evo",
    "password_env": "DB_PASSWORD",
    "pgvector_dim": 768
  },

  "redis": {
    "host": "redis",
    "port": 6379,
    "session_ttl_seconds": 86400,
    "write_queue_key": "evo:write_queue"
  },

  "shards": [
    {
      "id": "shard-01",
      "host": "FILL_IN_SHARD_HOST",
      "base_path": "/evo",
      "mirror": "FILL_IN_MIRROR_HOST",
      "max_gb": 15
    }
  ],

  "sleep_mode": {
    "window_recalc_cron": "0 23 * * *",
    "watchdog_interval_seconds": 30,
    "rps_interrupt_threshold": 0.9
  },

  "telegram": {
    "bot_token_env": "TG_BOT_TOKEN",
    "admin_chat_id_env": "TG_ADMIN_CHAT_ID"
  },

  "n8n": {
    "webhook_url_env": "N8N_WEBHOOK_URL",
    "timeout_seconds": 30
  }
}
